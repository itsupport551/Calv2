# Copy to .env.local for local dev, or set these in Vercel project settings.
#
# Get the Supabase URL + anon key from:
#   Supabase dashboard → your project → Settings → API
#
# The anon key is safe to ship to the browser — Row Level Security
# protects your data even with the anon key exposed.

NEXT_PUBLIC_SUPABASE_URL=https://ocusxtdlyzliiuhbolgv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key-here

# Your Railway backend URL.
NEXT_PUBLIC_API_URL=https://calv2-production.up.railway.app
