# ============================================================
# Enterprise Calendar Sync — Environment Configuration
# ============================================================
# Copy to .env and fill in real values. Never commit your .env.
# Every variable below is actually read by the code — nothing dead.
# ============================================================

# ============================================================
# 1. SERVER (3 vars — all optional with sensible defaults)
# ============================================================
NODE_ENV=development           # development | production
PORT=4400                      # Railway sets this automatically in prod
HOST=0.0.0.0                   # Always 0.0.0.0 in containers; localhost ok locally

# ============================================================
# 2. DATABASE (REQUIRED — Supabase or local Postgres)
# ============================================================
# Local Postgres: both URLs can be the same.
# Supabase: DATABASE_URL = transaction pooler (port 6543), DIRECT_URL = session pooler (port 5432)
DATABASE_URL=postgresql://postgres:password@localhost:5432/calendarsync_app
DIRECT_URL=postgresql://postgres:password@localhost:5432/calendarsync_app

# ============================================================
# 3. SECURITY SECRETS (REQUIRED — generate once, never share)
# ============================================================
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  → ENCRYPTION_KEY
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"  → JWT_SECRET
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  → SESSION_SECRET
ENCRYPTION_KEY=
JWT_SECRET=
SESSION_SECRET=
JWT_EXPIRES_IN=24h
ENCRYPTION_IV_LENGTH=16

# ============================================================
# 4. GOOGLE OAUTH (required to connect Google accounts)
# ============================================================
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4400/auth/google/callback

# ============================================================
# 5. MICROSOFT OAUTH (required to connect Outlook accounts)
# ============================================================
# portal.azure.com → App registrations → your app
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:4400/auth/microsoft/callback

# ============================================================
# 6. WEBHOOKS (used by the webhook auto-renewal service)
# ============================================================
# Must be a public HTTPS URL. Use the Railway URL in production.
WEBHOOK_BASE_URL=http://localhost:4400
GOOGLE_WEBHOOK_URL=
MICROSOFT_WEBHOOK_URL=

# ============================================================
# 7. CORS + RATE LIMIT
# ============================================================
# Comma-separated origins. Add your Vercel frontend URL here in prod.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4400
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# 8. LOGGING
# ============================================================
LOG_LEVEL=info                 # debug | info | warn | error
LOG_FORMAT=pretty              # pretty (local) | json (production)

# ============================================================
# 9. EMAIL / SMTP (for notifications when AUTO routing falls back)
# ============================================================
# Gmail: enable 2FA → myaccount.google.com/apppasswords → use the 16-char password
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=your-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ============================================================
# 10. ADMIN DASHBOARD URL (for OAuth login redirects back to frontend)
# ============================================================
# Local: http://localhost:3000. Production: your Vercel URL.
ADMIN_DASHBOARD_URL=http://localhost:3000
